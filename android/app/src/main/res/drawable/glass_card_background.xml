<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Gradient Background -->
    <gradient
        android:angle="135"
        android:startColor="#0FFFFFFF"
        android:centerColor="#1AFFFFFF"
        android:endColor="#08FFFFFF"
        android:type="linear" />

    <!-- Blur effect (simulated with transparency) -->
    <solid android:color="#40000000" />

    <!-- Border -->
    <stroke
        android:width="1dp"
        android:color="#0FFFFFFF" />

    <!-- Corner Radius -->
    <corners android:radius="16dp" />

</shape>
