<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40DFD0B8">

    <item>
        <shape android:shape="rectangle">
            <!-- Primary Sand Gradient -->
            <gradient
                android:angle="135"
                android:startColor="#F2DFD0B8"
                android:centerColor="#E0B8A88C"
                android:endColor="#CCB8A88C"
                android:type="linear" />
            <solid android:color="#00000000" />
            <stroke
                android:width="1dp"
                android:color="#26FFFFFF" />
            <corners android:radius="12dp" />
        </shape>
    </item>

</ripple>
