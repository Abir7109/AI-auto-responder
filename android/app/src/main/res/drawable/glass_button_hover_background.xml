<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state - scale down to 0.95 -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#14FFFFFF"
                android:endColor="#05FFFFFF"
                android:angle="135"/>
            <corners android:radius="12dp"/>
            <stroke android:width="1dp" android:color="#33FFFFFF"/>
        </shape>
    </item>
    <!-- Focused state - slight highlight -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0DFFFFFF"
                android:endColor="#05FFFFFF"
                android:angle="135"/>
            <corners android:radius="12dp"/>
            <stroke android:width="1dp" android:color="#1AFFFFFF"/>
        </shape>
    </item>
    <!-- Hover state - white 5% overlay -->
    <item android:state_hovered="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0DFFFFFF"
                android:endColor="#05FFFFFF"
                android:angle="135"/>
            <corners android:radius="12dp"/>
            <stroke android:width="1dp" android:color="#0DFFFFFF"/>
        </shape>
    </item>
    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0DFFFFFF"
                android:endColor="#05FFFFFF"
                android:angle="135"/>
            <corners android:radius="12dp"/>
            <stroke android:width="1dp" android:color="#0DFFFFFF"/>
        </shape>
    </item>
</selector>
