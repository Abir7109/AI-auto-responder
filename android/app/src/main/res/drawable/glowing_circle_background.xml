<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#20DFD0B8"/>
            <size android:width="120dp" android:height="120dp"/>
        </shape>
    </item>
    <!-- Middle glow -->
    <item android:left="10dp" android:top="10dp" android:right="10dp" android:bottom="10dp">
        <shape android:shape="oval">
            <solid android:color="#30DFD0B8"/>
        </shape>
    </item>
    <!-- Inner circle -->
    <item android:left="20dp" android:top="20dp" android:right="20dp" android:bottom="20dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="40dp"
                android:startColor="#40DFD0B8"
                android:endColor="#00DFD0B8"/>
        </shape>
    </item>
</layer-list>
