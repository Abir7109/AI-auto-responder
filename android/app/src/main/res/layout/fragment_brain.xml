<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background"
    android:clipToPadding="false"
    android:paddingTop="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧠 My Brain"
            android:textColor="@color/foreground"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Teach AI about yourself for smarter replies"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"/>

        <!-- Profile Status Card -->
        <LinearLayout
            android:id="@+id/cardProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/glass_card_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/circle_background">

                <TextView
                    android:id="@+id/avatarInitial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="?"
                    android:textColor="@color/accent_sand"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/cardName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set up your profile"
                    android:textColor="@color/foreground"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvProfileStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to customize"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/editProfileBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_edit"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/accent_sand"/>
        </LinearLayout>

        <!-- Quick Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:id="@+id/cardFacts"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/glass_card_background"
                android:padding="14dp"
                android:layout_marginEnd="6dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvSnippetCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/accent_sand"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Knowledge"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardNotices"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/glass_card_background"
                android:padding="14dp"
                android:layout_marginStart="6dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvNoticeCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/accent_sand"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notices"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Behavior Settings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⚙️ AI Behavior"
                    android:textColor="@color/foreground"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvBehaviorStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active"
                    android:textColor="#4CAF50"
                    android:textSize="12sp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/chip_active_background"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Response Length -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reply Style"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupLength"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipShort"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/chip_background_color"
                    android:textColor="@color/chip_text_color" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Normal"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/chip_background_color"
                    android:textColor="@color/chip_text_color" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipLong"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detailed"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/chip_background_color"
                    android:textColor="@color/chip_text_color" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Availability -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Your Status"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAvailable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅ Available"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="@color/chip_background_color"
                        android:textColor="@color/chip_text_color" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipBusy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⛔ Busy"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="@color/chip_background_color"
                        android:textColor="@color/chip_text_color" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipMeeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅 Meeting"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="@color/chip_background_color"
                        android:textColor="@color/chip_text_color" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipWorking"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💻 Working"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="@color/chip_background_color"
                        android:textColor="@color/chip_text_color" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipCustomAvailability"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="➕ Custom"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="@color/chip_background_color"
                        android:textColor="@color/chip_text_color" />
                </LinearLayout>
            </HorizontalScrollView>

            <EditText
                android:id="@+id/etAvailability"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/glass_input_background"
                android:hint="Type custom status..."
                android:inputType="text"
                android:paddingHorizontal="12dp"
                android:textColor="@color/foreground"
                android:textColorHint="@color/hint"
                android:textSize="14sp"/>

            <Button
                android:id="@+id/btnSaveBehavior"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/glass_button_primary_hover_background"
                android:text="Save"
                android:textColor="@color/obsidian_dark"
                android:textSize="14sp"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Profile Form (Hidden by default) -->
        <LinearLayout
            android:id="@+id/profileFormContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤 Your Profile"
                android:textColor="@color/foreground"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/glass_input_background"
                    android:hint="Name"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/foreground"
                    android:textColorHint="@color/hint"
                    android:textSize="14sp"
                    android:layout_marginEnd="6dp"/>

                <EditText
                    android:id="@+id/etProfession"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/glass_input_background"
                    android:hint="Profession"
                    android:inputType="text"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/foreground"
                    android:textColorHint="@color/hint"
                    android:textSize="14sp"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

            <EditText
                android:id="@+id/etBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="60dp"
                android:background="@drawable/glass_input_background"
                android:hint="Short bio..."
                android:inputType="textMultiLine"
                android:gravity="top"
                android:padding="10dp"
                android:textColor="@color/foreground"
                android:textColorHint="@color/hint"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/etHobbies"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/glass_input_background"
                android:hint="Hobbies"
                android:inputType="text"
                android:paddingHorizontal="12dp"
                android:textColor="@color/foreground"
                android:textColorHint="@color/hint"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/etLocation"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/glass_input_background"
                    android:hint="Location"
                    android:inputType="text"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/foreground"
                    android:textColorHint="@color/hint"
                    android:textSize="14sp"
                    android:layout_marginEnd="6dp"/>

                <EditText
                    android:id="@+id/etAge"
                    android:layout_width="80dp"
                    android:layout_height="44dp"
                    android:background="@drawable/glass_input_background"
                    android:hint="Age"
                    android:inputType="number"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/foreground"
                    android:textColorHint="@color/hint"
                    android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnSaveProfile"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/glass_button_primary_hover_background"
                    android:text="Save"
                    android:textColor="@color/obsidian_dark"
                    android:textSize="14sp"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/cancelEditBtn"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/glass_card_background"
                    android:text="Cancel"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Knowledge Snippets Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💡 Knowledge"
                android:textColor="@color/foreground"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnAddSnippet"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/glass_button_primary_hover_background"
                android:text="+ Add"
                android:textColor="@color/obsidian_dark"
                android:textSize="12sp"
                android:paddingHorizontal="12dp"/>
        </LinearLayout>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp"
            android:background="@drawable/glass_card_background"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧠"
                android:textSize="28sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="No knowledge yet"
                android:textColor="@color/foreground"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Add facts about yourself"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- Snippets RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSnippets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

        <!-- Notice Board Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📌 Notice Board"
                android:textColor="@color/foreground"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Notice Empty State -->
        <LinearLayout
            android:id="@+id/noticeEmptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp"
            android:background="@drawable/glass_card_background"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📌"
                android:textSize="28sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="No notices"
                android:textColor="@color/foreground"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Important info appears here"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- Notice Board RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvNotices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>
</ScrollView>
