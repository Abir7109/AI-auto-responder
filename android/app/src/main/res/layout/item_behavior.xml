<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/glass_card_background"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvBehaviorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Behavior Name"
            android:textColor="@color/foreground"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvBehaviorDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick • Available"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvActiveStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Inactive"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:background="@drawable/chip_inactive_background"
        android:layout_marginEnd="8dp"/>

    <ImageView
        android:id="@+id/btnDeleteBehavior"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_delete"
        android:padding="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="@color/text_secondary"/>
</LinearLayout>
