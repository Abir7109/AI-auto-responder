<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background"
    android:clipToPadding="false"
    android:paddingTop="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="API Settings"
            android:textColor="@color/foreground"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- API Profile (Shows when API is saved) -->
        <LinearLayout
            android:id="@+id/apiProfileContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/circle_background">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_key"
                        app:tint="@color/accent_sand"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/profileNameText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="API Connected"
                        android:textColor="@color/foreground"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/profileModelText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ready to respond"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check"
                    app:tint="@color/green_400"/>
            </LinearLayout>

            <TextView
                android:id="@+id/changeApiText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to change API"
                android:textColor="@color/accent_sand"
                android:textSize="12sp"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- API Key Input -->
        <LinearLayout
            android:id="@+id/apiKeyInputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your API Key"
                android:textColor="@color/foreground"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paste your API key below - we'll auto-detect the service"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <EditText
                android:id="@+id/apiKeyInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/glass_input_background"
                android:hint="Paste your API key here..."
                android:inputType="text"
                android:paddingHorizontal="12dp"
                android:textColor="@color/foreground"
                android:textColorHint="@color/hint"
                android:layout_marginTop="12dp"/>

            <Button
                android:id="@+id/saveApiButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/primary_button_background"
                android:text="Connect API"
                android:textColor="@color/primary_foreground"/>
        </LinearLayout>

        <!-- Get API Guide Button -->
        <Button
            android:id="@+id/guideButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/glass_button_background"
            android:text="❓ How to Get API Key"
            android:textColor="@color/accent_sand"
            android:layout_marginBottom="16dp"/>

        <!-- Supported Services Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Supported Services (Free Tier Available)"
                android:textColor="@color/foreground"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- OpenAI -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="🤖"
                    android:textSize="16sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OpenAI - $5 free credit for new users"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Google Gemini -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="🔷"
                    android:textSize="16sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Google Gemini - 60 requests/minute free"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Anthropic Claude -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="🧠"
                    android:textSize="16sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Anthropic Claude - $5 free credit"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Groq -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="⚡"
                    android:textSize="16sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Groq - Totally free, fast inference"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Test AI Response -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Test AI Response"
                android:textColor="@color/foreground"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/testMessageInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp"
                android:background="@drawable/glass_input_background"
                android:hint="Type a test message..."
                android:gravity="top"
                android:padding="12dp"
                android:textColor="@color/foreground"
                android:textColorHint="@color/hint"/>

            <Button
                android:id="@+id/testAiButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/primary_button_background"
                android:text="Test Response"
                android:textColor="@color/primary_foreground"/>

            <ProgressBar
                android:id="@+id/testProgressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:indeterminateTint="@color/accent_sand"/>

            <LinearLayout
                android:id="@+id/testResponseContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/glass_card_light_background"
                android:padding="16dp"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Response:"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/testResponseText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/foreground"
                    android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Critical Alerts -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_background"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️ Critical Alerts"
                        android:textColor="@color/foreground"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pause bot for urgent messages"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"/>
                </LinearLayout>

                <Switch
                    android:id="@+id/criticalAlertsSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/accent_sand"
                    android:trackTint="@color/accent_sand"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/urgencyKeywordsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trigger Keywords"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/urgencyChipGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="emergency"
                        android:textColor="@color/foreground"
                        app:chipBackgroundColor="@color/surface_variant"
                        style="@style/Widget.Material3.Chip.Suggestion"/>

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="help"
                        android:textColor="@color/foreground"
                        app:chipBackgroundColor="@color/surface_variant"
                        style="@style/Widget.Material3.Chip.Suggestion"/>

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="urgent"
                        android:textColor="@color/foreground"
                        app:chipBackgroundColor="@color/surface_variant"
                        style="@style/Widget.Material3.Chip.Suggestion"/>

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="asap"
                        android:textColor="@color/foreground"
                        app:chipBackgroundColor="@color/surface_variant"
                        style="@style/Widget.Material3.Chip.Suggestion"/>

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="911"
                        android:textColor="@color/foreground"
                        app:chipBackgroundColor="@color/surface_variant"
                        style="@style/Widget.Material3.Chip.Suggestion"/>
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
