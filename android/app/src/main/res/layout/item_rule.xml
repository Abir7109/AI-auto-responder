<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="@drawable/glass_card_light_background"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/ruleTrigger"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trigger: hello"
            android:textColor="@color/foreground"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/ruleResponse"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Response: Hi there!"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/ruleType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Response"
            android:textColor="@color/accent_sand"
            android:textSize="11sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <ImageButton
        android:id="@+id/deleteRuleButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/glass_button_background"
        android:src="@drawable/ic_trash"
        app:tint="@color/foreground"
        android:contentDescription="Delete rule"/>
</LinearLayout>
