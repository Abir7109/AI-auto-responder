<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/obsidian_surface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Knowledge Snippet"
        android:textColor="@color/obsidian_text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add a fact about yourself that the AI should know"
        android:textColor="@color/obsidian_text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="20dp" />

    <!-- Keyword -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Keyword (what this is about)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/obsidian_accent"
        app:hintTextColor="@color/obsidian_text_secondary"
        app:helperText="e.g., 'dog', 'work', 'email', 'phone'">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etKeyword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/obsidian_text_primary" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Content -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="The Fact"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/obsidian_accent"
        app:hintTextColor="@color/obsidian_text_secondary"
        app:helperText="e.g., 'My dog's name is Rex'">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:textColor="@color/obsidian_text_primary" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Category -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category"
        android:textColor="@color/obsidian_text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipGeneral"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="General"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_background_color"
            android:textColor="@color/chip_text_color"
            android:checked="true" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipWork"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Work"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_background_color"
            android:textColor="@color/chip_text_color" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipPersonal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personal"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_background_color"
            android:textColor="@color/chip_text_color" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAvailability"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Availability"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_background_color"
            android:textColor="@color/chip_text_color" />

    </com.google.android.material.chip.ChipGroup>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="@color/obsidian_text_secondary"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Add Fact"
            android:textColor="@color/obsidian_background"
            app:backgroundTint="@color/obsidian_accent"
            app:cornerRadius="8dp" />

    </LinearLayout>

</LinearLayout>
